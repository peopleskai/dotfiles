#
# HomeBrew setup
#
if [ ! -f ~/.homebrewrc ]; then
    echo "No '~/.homebrewrc' found! Setup will not work correctly!!!"
else
    source ~/.homebrewrc
fi

#
# MISE Setup
#

# MISE installs tools used by rest of script. Need to run at the beginning
eval "$(~/.local/bin/mise activate zsh)"

#
# Load ZAP plugins
#
[ -f "${XDG_DATA_HOME:-$HOME/.local/share}/zap/zap.zsh" ] && source "${XDG_DATA_HOME:-$HOME/.local/share}/zap/zap.zsh"
plug "zsh-users/zsh-autosuggestions"
plug "zap-zsh/supercharge"
plug "zsh-users/zsh-syntax-highlighting"
plug "zap-zsh/sudo"
plug "zap-zsh/exa"

# Tools require compinit to be runned before it can initialize auto complete
# Load and initialise completion system
autoload -Uz compinit
compinit

# Load mise completions
# source ~/.local/share/mise/completions.zsh

#
# Zoxide Setup
#
eval "$(zoxide init zsh)"

#
# Bat Setup
#

# Replace cat with bat
alias cat=$(which bat)
export MANPAGER="sh -c 'col -bx | bat -l man -p'"

#
# fd Setup
#
fd --gen-completions zsh > ~/.zfunc/_fd

#
# FZF configurations
#

source <(fzf --zsh)

# Preview file content using bat (https://github.com/sharkdp/bat)
export FZF_CTRL_T_OPTS="
  --walker-skip .git,node_modules,target,build,.bemol,.brazil,.brazil,.builder-mcp
  --preview 'bat -n --color=always {}'
  --bind 'ctrl-/:change-preview-window(down|hidden|)'"

# CTRL-/ to toggle small preview window to see the full command
# CTRL-Y to copy the command into clipboard using pbcopy
export FZF_CTRL_R_OPTS="
  --bind 'ctrl-/:toggle-preview'
  --bind 'ctrl-y:execute-silent(echo -n {2..} | pbcopy)+abort'
  --color header:italic
  --header 'Press CTRL-Y to copy command into clipboard'"

# Print tree structure using eza (https://eza.rocks)
export FZF_ALT_C_OPTS="
  --walker-skip .git,node_modules,target,build,.bemol,.brazil
  --preview 'eza --tree {}'"

# Fuzy find git branches
fzf-git-branch() {
    git rev-parse HEAD > /dev/null 2>&1 || return

    git branch --color=always --all --sort=-committerdate |
        grep -v HEAD |
        fzf --height 50% --ansi --no-multi --preview-window right:65% \
            --preview 'git log -n 50 --color=always --date=short --pretty="format:%C(auto)%cd %h%d %s" $(sed "s/.* //" <<< {})' |
        sed "s/.* //"
}
alias gb='fzf-git-branch'

# Fuzy find & checkout a git branch
fzf-git-checkout() {
    git rev-parse HEAD > /dev/null 2>&1 || return

    local branch

    branch=$(fzf-git-branch)
    if [[ "$branch" = "" ]]; then
        echo "No branch selected."
        return
    fi

    # If branch name starts with 'remotes/' then it is a remote branch. By
    # using --track and a remote branch name, it is the same as:
    # git checkout -b branchName --track origin/branchName
    if [[ "$branch" = 'remotes/'* ]]; then
        git checkout --track $branch
    else
        git checkout $branch;
    fi
}
alias gco='fzf-git-checkout'

# disable sort when completing `git checkout`
zstyle ':completion:*:git-checkout:*' sort false
# set descriptions format to enable group support
# NOTE: don't use escape sequences here, fzf-tab will ignore them
zstyle ':completion:*:descriptions' format '[%d]'
# set list-colors to enable filename colorizing
zstyle ':completion:*' list-colors ${(s.:.)LS_COLORS}
# force zsh not to show completion menu, which allows fzf-tab to capture the unambiguous prefix
zstyle ':completion:*' menu no
# preview directory's content with eza when completing cd
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'eza -1 --color=always $realpath'
# switch group using `<` and `>`
zstyle ':fzf-tab:*' switch-group '<' '>'

#
# Generic Setup
#

export EDITOR='nvim'

# startship prompt
eval "$(starship init zsh)"

#
# Local settings
#
[ -f ~/.local_zshrc ] && source ~/.local_zshrc

[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh
